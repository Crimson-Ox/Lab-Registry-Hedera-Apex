 pragma solidity 0.8.18; // cats are cool 
   
   contract LabRegistry {

    // A CONTRACT RECORDING AND RETRIEVING LAB REPORTS 
    
    mapping (uint256 => string) public labReports; 

    // RECORDING PROCESS [READ AND UPDATE ]

     function addfunction(uint256 _id, string memory _results) public {
       labReports[_id] = _results;
     }

     // RETRIEVING PROCESS

     function getreports(uint256 _id) public view returns (string memory) {
        return labReports [_id];
     }
   }
   
